      "source": [
        "#soal 1 regresi dan interpolasi\n",
        "\n",
        "def model_exp(t, a, b):\n",
        "    return a * np.exp(b * t)\n",
        "\n",
        "popt, _ = curve_fit(model_exp, t, y, p0=[1000, 0.03], maxfev=10000)\n",
        "a, b = popt\n",
        "\n",
        "y_pred = model_exp(t, a, b)\n",
        "r2   = 1 - np.sum((y - y_pred)**2) / np.sum((y - np.mean(y))**2)\n",
        "rmse = np.sqrt(np.mean((y - y_pred)**2))\n",
        "\n",
        "print(f\"Model: f(t) = {a:.3e} * exp({b:.3e} * t)\")\n",
        "print(f\"R²   = {r2:.6f}\")\n",
        "print(f\"RMSE = {rmse:.3e}\")\n",
        "\n",
        "t_plot = np.linspace(1, 80, 300)\n",
        "plt.figure(figsize=(10,4))\n",
        "plt.plot(t, y, 'o', ms=4, color='steelblue', alpha=0.7, label='Data aktual')\n",
        "plt.plot(t_plot, model_exp(t_plot, a, b), '-', color='crimson', lw=2, label='Model eksponensial')\n",
        "plt.axhline(25000, color='orange', ls='--', lw=1.5, label='Kapasitas gudang (25.000)')\n",
        "plt.xlabel('Bulan ke-t'); plt.ylabel('Produksi (tas)')\n",
        "plt.title(f'Soal 1: Regresi Eksponensial | R²={r2:.4f}')\n",
        "plt.legend(); plt.grid(alpha=0.4); plt.tight_layout(); plt.show()"
