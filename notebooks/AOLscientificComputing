      "source": [
        "#soal 3 root of equations\n",
        "def g(t_val):\n",
        "    return f_taylor(t_val, a, b, N_pilih) - 25000\n",
        "\n",
        "# Cek bracket\n",
        "print(f\"g(60) = {g(60):.2f}\")\n",
        "print(f\"g(65) = {g(65):.2f}\")\n",
        "\n",
        "t_root = brentq(g, 60, 65, xtol=1e-9)\n",
        "t_bangun = t_root - 13\n",
        "\n",
        "tgl_awal  = date(2018, 1, 1)\n",
        "tgl_lampaui = tgl_awal + relativedelta(months=int(np.ceil(t_root)) - 1)\n",
        "tgl_bangun  = tgl_lampaui - relativedelta(months=13)\n",
        "\n",
        "print(f\"\\nKapasitas 25.000 dilampaui pada: t = {t_root:.3f} → {tgl_lampaui.strftime('%B %Y')}\")\n",
        "print(f\"EGIER harus mulai bangun gudang : t = {t_bangun:.3f} → {tgl_bangun.strftime('%B %Y')}\")\n",
        "\n",
        "t_plot2 = np.linspace(40, 78, 300)\n",
        "plt.figure(figsize=(10,4))\n",
        "plt.plot(t_plot2, [f_taylor(ti, a, b, N_pilih) for ti in t_plot2], color='crimson', lw=2, label='f(t) Taylor')\n",
        "plt.axhline(25000, color='orange', ls='--', lw=2, label='Kapasitas 25.000')\n",
        "plt.axvline(t_root,   color='green',  ls=':', lw=2, label=f'Dilampaui: t={t_root:.2f} ({tgl_lampaui.strftime(\"%b %Y\")})')\n",
        "plt.axvline(t_bangun, color='purple', ls=':', lw=2, label=f'Mulai bangun: t={t_bangun:.2f} ({tgl_bangun.strftime(\"%b %Y\")})')\n",
        "plt.xlabel('Bulan ke-t'); plt.ylabel('Produksi (tas/bulan)')\n",
        "plt.title('Soal 3: Pencarian Akar — Kapasitas Gudang')\n",
        "plt.legend(); plt.grid(alpha=0.4); plt.tight_layout(); plt.show()"
