        "#Soal 2 Deret taylor pake rumus deret tayloor\n",
        "\n",
        "def taylor_exp(x, N):\n",
        "    hasil = 0.0\n",
        "    for n in range(N):\n",
        "        hasil += (x**n) / math.factorial(n)\n",
        "    return hasil\n",
        "\n",
        "def f_taylor(t_val, a, b, N):\n",
        "    return a * taylor_exp(b * t_val, N)\n",
        "\n",
        "# Uji akurasi di t=72 (kondisi terburuk, x = b*72 paling besar)\n",
        "t_uji  = 72.0\n",
        "exact  = model_exp(t_uji, a, b)\n",
        "\n",
        "print(f\"Pengujian akurasi deret Taylor pada t={t_uji}\")\n",
        "print(f\"{'N':>6} | {'f_taylor':>14} | {'f_exact':>14} | {'Error Relatif':>14}\")\n",
        "print(\"-\" * 56)\n",
        "\n",
        "N_pilih = None\n",
        "for N in [5, 10, 15, 20, 25]:\n",
        "    approx  = f_taylor(t_uji, a, b, N)\n",
        "    err_rel = abs(exact - approx) / abs(exact)\n",
        "    tanda   = \" <- dipilih\" if err_rel < 1e-3 and N_pilih is None else \"\"\n",
        "    if N_pilih is None and err_rel < 1e-3:\n",
        "        N_pilih = N\n",
        "    print(f\"{N:>6} | {approx:>14.3e} | {exact:>14.3e} | {err_rel:>14.3e}{tanda}\")\n",
        "\n",
        "print(f\"\\nN = {N_pilih} suku dipilih (error relatif < 10⁻³)\")"
      ],
